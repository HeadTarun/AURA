# =============================================================================
# Hackathon Starter — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values before running docker compose.
# NEVER commit secrets to version control.
# =============================================================================

# Domain (leave as localhost for local dev)
DOMAIN=localhost

# Frontend host (used by backend for CORS)
FRONTEND_HOST=http://localhost:3000

# Environment: local | staging | production
ENVIRONMENT=local

PROJECT_NAME="Hackathon Starter"
STACK_NAME=hackathon-starter

# Local host ports exposed by Docker Compose
BACKEND_PORT=8001
FRONTEND_PORT=3000
POSTGRES_HOST_PORT=5433
ADMINER_PORT=8081
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8090

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# Allowed CORS origins (comma-separated)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# JWT secret — change this in production!
SECRET_KEY=8f3d9a7c2b1e4f6a9d8c7b2e1f3a6d9c4b7e2f1a9c6d8e3f

# Initial superuser created on first run
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# ---------------------------------------------------------------------------
# Optional (leave empty to disable)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=


GROQ_API_KEY = 
GEMINI_API_KEY =